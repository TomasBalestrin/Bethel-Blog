# Supabase — Public (expostas no browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Server-only (NUNCA NEXT_PUBLIC_)
# project-id usado em `supabase gen types typescript --project-id $SUPABASE_PROJECT_ID`
SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=

# Segredos server-only
CRON_SECRET=
LIKE_HASH_SALT=

# Opcional — rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
